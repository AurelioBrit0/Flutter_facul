{
  "name": "api-camadas",
  "version": "1.0.0",
  "description": "API NestJS + Node.js + TypeScript com arquitetura em camadas",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "migrate": "node-pg-migrate up -f .pgmigrate.cjs",
    "migrate:down": "node-pg-migrate down -f .pgmigrate.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.10.9",
    "node-pg-migrate": "^7.6.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
